# bron_mod — конфигурация Caddy.
# Замените admin.example.ru на свой домен админки.
#
# Домены ОБЪЕКТОВ задаются в админке (поле «Домен») и работают автоматически:
# пользователь направляет поддомен (A-запись DNS) на IP этого сервера — и всё.
# Caddy выпускает TLS-сертификат «по запросу» (On-Demand TLS), спрашивая у
# приложения, привязан ли домен к реальному объекту (эндпоинт /api/tls-check).

# --- 1. Глобальный блок (должен быть в самом верху основного Caddyfile, один раз) ---
{
	on_demand_tls {
		ask http://127.0.0.1:3015/api/tls-check
	}
}

# --- 2. Админка (отдельный домен, обычный сертификат) ---
admin.example.ru {
	request_body {
		max_size 25MB
	}
	reverse_proxy 127.0.0.1:3015
}

# --- 3. Любой домен объекта (сертификат по запросу) ---
# Этот блок ловит все остальные домены, указывающие на сервер. Сертификат
# выпускается только если домен подтверждён эндпоинтом /api/tls-check.
https:// {
	tls {
		on_demand
	}
	request_body {
		max_size 25MB
	}
	reverse_proxy 127.0.0.1:3015
}
