# ==== БАЗА ДАННЫХ (PostgreSQL в docker-compose) ====
POSTGRES_USER=bron
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bron_mod
# DATABASE_URL собирается из переменных выше и указывает на сервис postgres внутри compose.
# В приложении используется как есть:
DATABASE_URL=postgresql://bron:change_me_strong_password@postgres:5432/bron_mod?schema=public

# ==== АДМИН (главный супер-админ — из env) ====
# Логин главного админа.
ADMIN_LOGIN=admin
# bcrypt-хэш пароля (НЕ сам пароль!). Сгенерировать:
#   node -e "console.log(require('bcryptjs').hashSync('ВАШ_ПАРОЛЬ', 10))"
ADMIN_PASSWORD_HASH=$2a$10$replace_with_real_bcrypt_hash
# Секрет для подписи JWT сессии админа (длинная случайная строка):
#   openssl rand -base64 48
ADMIN_JWT_SECRET=change_me_long_random_secret

# ==== ДОМЕНЫ / ИНТЕГРАЦИЯ С TILDA ====
# Домен админки. На нём доступны только /admin и /api/admin (см. middleware.ts).
ADMIN_DOMAIN=admin.example.ru
# Базовый URL для метаданных/canonical. Публичные домены ОБЪЕКТОВ задаются в
# админке (поле «Домен» объекта), а не здесь.
NEXT_PUBLIC_SITE_URL=https://admin.example.ru

# ==== СБОРКА ====
# При билде БД недоступна — пропускаем обращения к ней.
SKIP_DB_DURING_BUILD=1
NODE_ENV=production
